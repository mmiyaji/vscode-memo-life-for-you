{
  "name": "memo-life-for-you-admin",
  "displayName": "Memo Life For You Admin",
  "description": "Daily memo workflow for VS Code with date-based folders, search tools, and a memo admin dashboard.",
  "version": "0.6.3",
  "publisher": "mmiyaji",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "memo",
    "notes",
    "markdown",
    "journal",
    "productivity"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "icon": "media/icon.png",
  "homepage": "https://github.com/mmiyaji/vscode-memo-life-for-you",
  "bugs": {
    "url": "https://github.com/mmiyaji/vscode-memo-life-for-you/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mmiyaji/vscode-memo-life-for-you"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension",
  "contributes": {
    "configurationDefaults": {
      "[markdown]": {
        "editor.quickSuggestions": {
          "other": "on",
          "comments": "off",
          "strings": "off"
        }
      }
    },
    "commands": [
      {
        "command": "extension.memoNew",
        "title": "%extension.memoNew.title%"
      },
      {
        "command": "extension.memoEdit",
        "title": "%extension.memoEdit.title%",
        "icon": {
          "light": "./resources/Q2xhdWRpYV8x.png",
          "dark": "./resources/Q2xhdWRpYV8x.png"
        }
      },
      {
        "command": "extension.memoQuick",
        "title": "%extension.memoQuick.title%"
      },
      {
        "when": "!config.memo-life-for-you.withRespectMode",
        "command": "extension.memoGrep",
        "title": "%extension.memoGrep.title%"
      },
      {
        "when": "config.memo-life-for-you.withRespectMode",
        "command": "extension.memoGrep",
        "title": "%extension.memoGrep.title%",
        "icon": {
          "light": "./resources/44Kv44Op44Km44OH44Kj44Ki44OQ44K544OI44OI44OD44OX.png",
          "dark": "./resources/44Kv44Op44Km44OH44Kj44Ki44OQ44K544OI44OI44OD44OX.png"
        }
      },
      {
        "command": "extension.memoConfig",
        "title": "%extension.memoConfig.title%"
      },
      {
        "when": "!config.memo-life-for-you.memoPath",
        "command": "extension.memoServe",
        "title": "%extension.memoServe.title%"
      },
      {
        "command": "extension.memoReDate",
        "title": "%extension.memoReDate.title%"
      },
      {
        "command": "extension.memoTodo",
        "title": "%extension.memoTodo.title%"
      },
      {
        "command": "extension.memoOpenFolder",
        "title": "%extension.memoOpenFolder.title%"
      },
      {
        "command": "extension.memoOpenChrome",
        "title": "%extension.memoOpenChrome.title%"
      },
      {
        "command": "extension.memoOpenTypora",
        "title": "%extension.memoOpenTypora.title%"
      },
      {
        "command": "extension.memoAdmin",
        "title": "%extension.memoAdmin.title%"
      }
    ],
    "keybindings": [
      {
        "command": "extension.memoNew",
        "key": "ctrl+alt+n",
        "when": "editorTextFocus || !editorFocus"
      },
      {
        "command": "extension.memoQuick",
        "key": "ctrl+alt+t",
        "when": "editorTextFocus || !editorFocus"
      },
      {
        "command": "extension.memoGrep",
        "key": "ctrl+alt+g",
        "when": "editorTextFocus || !editorFocus"
      },
      {
        "command": "extension.memoAdmin",
        "key": "ctrl+alt+m",
        "when": "editorTextFocus || !editorFocus"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "extension.memoOpenTypora",
          "title": "%extension.memoOpenTypora.title%",
          "when": "isMac"
        },
        {
          "command": "extension.memoAdmin",
          "title": "%extension.memoAdmin.title%"
        }
      ],
      "editor/title": [
        {
          "when": "config.memo-life-for-you.withRespectMode",
          "command": "extension.memoEdit",
          "alt": "extension.memoGrep",
          "group": "navigation@1120"
        }
      ],
      "editor/context": [
        {
          "command": "extension.memoNew",
          "title": "Memo: New",
          "group": "memo@1"
        },
        {
          "command": "extension.memoEdit",
          "group": "memo@2"
        },
        {
          "command": "extension.memoQuick",
          "group": "memo@3"
        },
        {
          "command": "extension.memoGrep",
          "group": "memo@4"
        },
        {
          "command": "extension.memoServe",
          "group": "memo@5"
        }
      ]
    },
    "configuration": [
      {
        "title": "%config.group.general%",
        "properties": {
          "memo-life-for-you.memoPath": {
            "type": "string",
            "default": "",
            "description": "%memoPath.desc%"
          },
          "memo-life-for-you.memoconfdir": {
            "type": "string",
            "default": "",
            "description": "%memoConfDir.desc%"
          },
          "memo-life-for-you.serve-addr": {
            "type": "string",
            "default": "8080",
            "description": "%serve-addr.desc%"
          },
          "memo-life-for-you.memoDisplayLanguage": {
            "type": "string",
            "enum": [
              "auto",
              "en",
              "ja"
            ],
            "default": "auto",
            "description": "%memoDisplayLanguage.desc%"
          }
        }
      },
      {
        "title": "%config.group.newMemo%",
        "properties": {
          "memo-life-for-you.titlePrefix": {
            "type": "string",
            "default": "## ",
            "description": "%titlePrefix.desc%"
          },
          "memo-life-for-you.dateFormat": {
            "type": "string",
            "default": "yyyy-MM-dd HH:mm",
            "description": "%dateFormat.desc%"
          },
          "memo-life-for-you.insertISOWeek": {
            "type": "boolean",
            "default": false,
            "description": "%insertISOWeek.desc%"
          },
          "memo-life-for-you.insertEmoji": {
            "type": "boolean",
            "default": false,
            "description": "%insertEmoji.desc%"
          },
          "memo-life-for-you.memoNewFilenameFromClipboard": {
            "type": "boolean",
            "default": false,
            "description": "%memoNewFilenameFromClipboard.desc%"
          },
          "memo-life-for-you.memoNewFilenameFromSelection": {
            "type": "boolean",
            "default": false,
            "description": "%memoNewFilenameFromSelection.desc%"
          },
          "memo-life-for-you.memoNewFilNameDateSuffix": {
            "type": "string",
            "default": "",
            "description": "%memoNewFilNameDateSuffix.desc%"
          },
          "memo-life-for-you.memoTemplatesDir": {
            "type": "string",
            "default": "",
            "description": "%memoTemplatesDir.desc%"
          },
          "memo-life-for-you.memoSnippetsDir": {
            "type": "string",
            "default": "",
            "description": "%memoSnippetsDir.desc%"
          },
          "memo-life-for-you.memoDatePathFormat": {
            "type": "string",
            "default": "",
            "description": "%memoDatePathFormat.desc%"
          }
        }
      },
      {
        "title": "%config.group.listEdit%",
        "properties": {
          "memo-life-for-you.listSortOrder": {
            "type": "string",
            "enum": [
              "filename",
              "birthtime",
              "mtime"
            ],
            "default": "filename",
            "description": "%listSortOrder.desc%"
          },
          "memo-life-for-you.displayFileBirthTime": {
            "type": "boolean",
            "default": false,
            "description": "%displayFileBirthTime.desc%"
          },
          "memo-life-for-you.listDisplayExtname": {
            "type": "array",
            "default": [
              "md",
              "txt"
            ],
            "description": "%memolistDisplayExtname.desc%"
          },
          "memo-life-for-you.listMarkdownPreview": {
            "type": "boolean",
            "default": false,
            "description": "%openMarkdownPreview.desc%"
          }
        }
      },
      {
        "title": "%config.group.grep%",
        "properties": {
          "memo-life-for-you.memoGrepViewMode": {
            "type": "string",
            "enum": [
              "quickPick",
              "outputChannel",
              "readOnlyDocument",
              "editableDocument"
            ],
            "default": "quickPick",
            "description": "%memoGrepViewMode.desc%"
          },
          "memo-life-for-you.gutterIconPath": {
            "type": "string",
            "default": "",
            "description": "%gutterIconPath.desc%"
          },
          "memo-life-for-you.gutterIconSize": {
            "type": "string",
            "default": "100%",
            "description": "%gutterIconSize.desc%"
          },
          "memo-life-for-you.withRespectMode": {
            "type": "boolean",
            "default": false,
            "description": "%withRespectMode.desc%"
          },
          "memo-life-for-you.grepLineBackgroundColor": {
            "type": "string",
            "default": "rgba(201, 9, 38, 0.3)",
            "description": "%grepLineBackgroundColor.desc%"
          },
          "memo-life-for-you.grepKeywordBackgroundColor": {
            "type": "string",
            "default": "rgba(255, 255, 255, 0.4)",
            "description": "%grepKeywordBackgroundColor.desc%"
          },
          "memo-life-for-you.memoGrepUseRipGrepConfigFile": {
            "type": "boolean",
            "default": false,
            "description": "%memoGrepUseRipGrepConfigFile.desc%"
          },
          "memo-life-for-you.memoGrepUseRipGrepConfigFilePath": {
            "type": "string",
            "default": "",
            "description": "%memoGrepUseRipGrepConfigFilePath.desc%"
          },
          "memo-life-for-you.memoTodoUserePattern": {
            "type": "string",
            "default": "^.*@todo.*?:",
            "description": "%memoTodoUserePattern.desc%"
          }
        }
      },
      {
        "title": "%config.group.admin%",
        "properties": {
          "memo-life-for-you.memoAdminAppearance": {
            "type": "string",
            "enum": [
              "system",
              "light",
              "dark"
            ],
            "default": "system",
            "description": "%memoAdminAppearance.desc%"
          },
          "memo-life-for-you.memoAdminColorTheme": {
            "type": "string",
            "enum": [
              "blue",
              "teal",
              "amber",
              "rose",
              "mono",
              "forest"
            ],
            "default": "blue",
            "description": "%memoAdminColorTheme.desc%"
          },
          "memo-life-for-you.memoAdminUseGradient": {
            "type": "boolean",
            "default": false,
            "description": "%memoAdminUseGradient.desc%"
          },
          "memo-life-for-you.memoAdminOpenMode": {
            "type": "string",
            "enum": [
              "currentWindow",
              "newWindow"
            ],
            "default": "currentWindow",
            "markdownDescription": "%memoAdminOpenMode.desc%"
          },
          "memo-life-for-you.memoAdminOpenOnStartup": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%memoAdminOpenOnStartup.desc%"
          },
          "memo-life-for-you.memoPinnedFiles": {
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            },
            "description": "%memoPinnedFiles.desc%"
          }
        }
      },
      {
        "title": "%config.group.markdownPreview%",
        "properties": {
          "memo-life-for-you.openMarkdownPreview": {
            "type": "boolean",
            "default": false,
            "description": "%openMarkdownPreview.desc%"
          },
          "memo-life-for-you.openMarkdownPreviewUseMPE": {
            "type": "boolean",
            "default": false,
            "description": "%openMarkdownPreviewUseMPE.desc%"
          }
        }
      },
      {
        "title": "%config.group.externalTools%",
        "properties": {
          "memo-life-for-you.openChromeCustomizeURL": {
            "type": "string",
            "default": "data:text/html, <html contenteditable>",
            "description": "%openChromeCustomizeURL.desc%"
          },
          "memo-life-for-you.TyporaExecPath": {
            "type": "string",
            "default": "",
            "description": "%openTyporaExecPath.desc%"
          }
        }
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/markdown.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "webpack": "webpack --mode development",
    "webpack-dev": "webpack --mode development --watch",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.json -w",
    "test-compile": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint src",
    "test": "npm run compile-tests && node --test out/test/test"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.8",
    "@types/mustache": "^4.2.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.0",
    "del": "^8.0.0",
    "eslint": "^9.11.1",
    "event-stream": "^4.0.1",
    "glob": "^11.0.0",
    "gulp": "^5.0.0",
    "gulp-filter": "^9.0.1",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-typescript": "^5.0.1",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.2",
    "vscode-nls-dev": "^4.0.4",
    "webpack": "^5.95.0",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "chrome-launcher": "^1.2.1",
    "date-fns": "^4.1.0",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "mustache": "^4.2.0",
    "node-emoji": "^1.11.0",
    "tomlify-j0.4": "^3.0.0",
    "upath": "^2.0.1",
    "vscode-nls": "^5.2.0"
  }
}
