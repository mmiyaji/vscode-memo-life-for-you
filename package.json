{
  "name": "vscode-memobox",
  "displayName": "MemoBox",
  "description": "Daily memo workflow for VS Code with date-based folders, search tools, and a memo admin dashboard.",
  "version": "0.6.3",
  "publisher": "mmiyaji",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "memo",
    "notes",
    "markdown",
    "journal",
    "productivity"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "icon": "media/icon.png",
  "homepage": "https://github.com/mmiyaji/vscode-memobox",
  "bugs": {
    "url": "https://github.com/mmiyaji/vscode-memobox/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mmiyaji/vscode-memobox"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension",
  "contributes": {
    "configurationDefaults": {
      "[markdown]": {
        "editor.quickSuggestions": {
          "other": "on",
          "comments": "off",
          "strings": "off"
        }
      },
      "markdown.copyFiles.destination": {
        "*": "assets/${isoTime/^(\\d+)-(\\d+)-(\\d+)T(\\d+):(\\d+):(\\d+).+/$1$2$3-$4$5$6/}.${fileExtName}"
      }
    },
    "commands": [
      {
        "command": "extension.memoNew",
        "title": "%extension.memoNew.title%"
      },
      {
        "command": "extension.memoEdit",
        "title": "%extension.memoEdit.title%",
        "icon": {
          "light": "./resources/Q2xhdWRpYV8x.png",
          "dark": "./resources/Q2xhdWRpYV8x.png"
        }
      },
      {
        "command": "extension.memoQuick",
        "title": "%extension.memoQuick.title%"
      },
      {
        "when": "!config.memobox.withRespectMode",
        "command": "extension.memoGrep",
        "title": "%extension.memoGrep.title%"
      },
      {
        "when": "config.memobox.withRespectMode",
        "command": "extension.memoGrep",
        "title": "%extension.memoGrep.title%",
        "icon": {
          "light": "./resources/44Kv44Op44Km44OH44Kj44Ki44OQ44K544OI44OI44OD44OX.png",
          "dark": "./resources/44Kv44Op44Km44OH44Kj44Ki44OQ44K544OI44OI44OD44OX.png"
        }
      },
      {
        "command": "extension.memoConfig",
        "title": "%extension.memoConfig.title%"
      },
      {
        "command": "extension.memoReDate",
        "title": "%extension.memoReDate.title%"
      },
      {
        "command": "extension.memoTodo",
        "title": "%extension.memoTodo.title%"
      },
      {
        "command": "extension.memoOpenFolder",
        "title": "%extension.memoOpenFolder.title%"
      },
      {
        "command": "extension.memoOpenChrome",
        "title": "%extension.memoOpenChrome.title%"
      },
      {
        "command": "extension.memoAdmin",
        "title": "%extension.memoAdmin.title%"
      },
      {
        "command": "extension.memoAutoTag",
        "title": "%extension.memoAutoTag.title%"
      },
      {
        "command": "extension.memoSummarize",
        "title": "%extension.memoSummarize.title%"
      },
      {
        "command": "extension.memoRelated",
        "title": "%extension.memoRelated.title%"
      },
      {
        "command": "extension.memoExtractTodos",
        "title": "%extension.memoExtractTodos.title%"
      },
      {
        "command": "extension.memoReport",
        "title": "%extension.memoReport.title%"
      },
      {
        "command": "extension.memoProofread",
        "title": "%extension.memoProofread.title%"
      },
      {
        "command": "extension.memoQA",
        "title": "%extension.memoQA.title%"
      },
      {
        "command": "extension.memoSuggestTemplate",
        "title": "%extension.memoSuggestTemplate.title%"
      },
      {
        "command": "extension.memoGenerateTitle",
        "title": "%extension.memoGenerateTitle.title%"
      },
      {
        "command": "extension.memoTranslate",
        "title": "%extension.memoTranslate.title%"
      },
      {
        "command": "extension.memoLinkSuggest",
        "title": "%extension.memoLinkSuggest.title%"
      }
    ],
    "keybindings": [
      {
        "command": "extension.memoNew",
        "key": "ctrl+alt+n",
        "when": "editorTextFocus || !editorFocus"
      },
      {
        "command": "extension.memoQuick",
        "key": "ctrl+alt+t",
        "when": "editorTextFocus || !editorFocus"
      },
      {
        "command": "extension.memoGrep",
        "key": "ctrl+alt+g",
        "when": "editorTextFocus || !editorFocus"
      },
      {
        "command": "extension.memoAdmin",
        "key": "ctrl+alt+shift+m",
        "when": "editorTextFocus || !editorFocus"
      }
    ],
    "submenus": [
      {
        "id": "memo.submenu",
        "label": "Memo"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "extension.memoAdmin",
          "title": "%extension.memoAdmin.title%"
        },
        {
          "command": "extension.memoAutoTag",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoSummarize",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoRelated",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoExtractTodos",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoReport",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoProofread",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoQA",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoSuggestTemplate",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoGenerateTitle",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoTranslate",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoLinkSuggest",
          "when": "config.memobox.aiEnabled"
        }
      ],
      "editor/title": [
        {
          "when": "config.memobox.withRespectMode",
          "command": "extension.memoEdit",
          "alt": "extension.memoGrep",
          "group": "navigation@1120"
        }
      ],
      "editor/context": [
        {
          "submenu": "memo.submenu",
          "group": "memo@1",
          "when": "editorLangId == markdown"
        }
      ],
      "memo.submenu": [
        {
          "command": "extension.memoNew",
          "group": "1_basic@1"
        },
        {
          "command": "extension.memoEdit",
          "group": "1_basic@2"
        },
        {
          "command": "extension.memoQuick",
          "group": "1_basic@3"
        },
        {
          "command": "extension.memoGrep",
          "group": "1_basic@4"
        },
        {
          "command": "extension.memoAdmin",
          "group": "1_basic@5"
        },
        {
          "command": "extension.memoAutoTag",
          "group": "2_ai@1",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoSummarize",
          "group": "2_ai@2",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoGenerateTitle",
          "group": "2_ai@3",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoProofread",
          "group": "2_ai@4",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoTranslate",
          "group": "2_ai@5",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoQA",
          "group": "2_ai@6",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoRelated",
          "group": "3_ai_multi@1",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoLinkSuggest",
          "group": "3_ai_multi@2",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoExtractTodos",
          "group": "3_ai_multi@3",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoReport",
          "group": "3_ai_multi@4",
          "when": "config.memobox.aiEnabled"
        },
        {
          "command": "extension.memoSuggestTemplate",
          "group": "3_ai_multi@5",
          "when": "config.memobox.aiEnabled"
        }
      ]
    },
    "configuration": [
      {
        "title": "%config.group.general%",
        "properties": {
          "memobox.memodir": {
            "type": "string",
            "default": "",
            "description": "%memodir.desc%"
          },
          "memobox.memotemplate": {
            "type": "string",
            "default": "",
            "description": "%memotemplate.desc%"
          },
          "memobox.memoDisplayLanguage": {
            "type": "string",
            "enum": [
              "auto",
              "en",
              "ja"
            ],
            "default": "auto",
            "description": "%memoDisplayLanguage.desc%"
          }
        }
      },
      {
        "title": "%config.group.newMemo%",
        "properties": {
          "memobox.titlePrefix": {
            "type": "string",
            "default": "## ",
            "description": "%titlePrefix.desc%"
          },
          "memobox.dateFormat": {
            "type": "string",
            "default": "yyyy-MM-dd HH:mm",
            "description": "%dateFormat.desc%"
          },
          "memobox.insertISOWeek": {
            "type": "boolean",
            "default": false,
            "description": "%insertISOWeek.desc%"
          },
          "memobox.insertEmoji": {
            "type": "boolean",
            "default": false,
            "description": "%insertEmoji.desc%"
          },
          "memobox.memoNewFilenameFromClipboard": {
            "type": "boolean",
            "default": false,
            "description": "%memoNewFilenameFromClipboard.desc%"
          },
          "memobox.memoNewFilenameFromSelection": {
            "type": "boolean",
            "default": false,
            "description": "%memoNewFilenameFromSelection.desc%"
          },
          "memobox.memoNewFilNameDateSuffix": {
            "type": "string",
            "default": "",
            "description": "%memoNewFilNameDateSuffix.desc%"
          },
          "memobox.memoTemplatesDir": {
            "type": "string",
            "default": "",
            "description": "%memoTemplatesDir.desc%"
          },
          "memobox.memoSnippetsDir": {
            "type": "string",
            "default": "",
            "description": "%memoSnippetsDir.desc%"
          },
          "memobox.memoDatePathFormat": {
            "type": "string",
            "default": "",
            "description": "%memoDatePathFormat.desc%"
          }
        }
      },
      {
        "title": "%config.group.listEdit%",
        "properties": {
          "memobox.listSortOrder": {
            "type": "string",
            "enum": [
              "filename",
              "birthtime",
              "mtime"
            ],
            "default": "filename",
            "description": "%listSortOrder.desc%"
          },
          "memobox.displayFileBirthTime": {
            "type": "boolean",
            "default": false,
            "description": "%displayFileBirthTime.desc%"
          },
          "memobox.listDisplayExtname": {
            "type": "array",
            "default": [
              "md",
              "txt"
            ],
            "description": "%memolistDisplayExtname.desc%"
          },
          "memobox.listMarkdownPreview": {
            "type": "boolean",
            "default": false,
            "description": "%openMarkdownPreview.desc%"
          }
        }
      },
      {
        "title": "%config.group.grep%",
        "properties": {
          "memobox.memoGrepViewMode": {
            "type": "string",
            "enum": [
              "quickPick",
              "outputChannel",
              "readOnlyDocument",
              "editableDocument"
            ],
            "default": "quickPick",
            "description": "%memoGrepViewMode.desc%"
          },
          "memobox.gutterIconPath": {
            "type": "string",
            "default": "",
            "description": "%gutterIconPath.desc%"
          },
          "memobox.gutterIconSize": {
            "type": "string",
            "default": "100%",
            "description": "%gutterIconSize.desc%"
          },
          "memobox.withRespectMode": {
            "type": "boolean",
            "default": false,
            "description": "%withRespectMode.desc%"
          },
          "memobox.grepLineBackgroundColor": {
            "type": "string",
            "default": "rgba(201, 9, 38, 0.3)",
            "description": "%grepLineBackgroundColor.desc%"
          },
          "memobox.grepKeywordBackgroundColor": {
            "type": "string",
            "default": "rgba(255, 255, 255, 0.4)",
            "description": "%grepKeywordBackgroundColor.desc%"
          },
          "memobox.memoGrepUseRipGrepConfigFile": {
            "type": "boolean",
            "default": false,
            "description": "%memoGrepUseRipGrepConfigFile.desc%"
          },
          "memobox.memoGrepUseRipGrepConfigFilePath": {
            "type": "string",
            "default": "",
            "description": "%memoGrepUseRipGrepConfigFilePath.desc%"
          },
          "memobox.memoTodoUserePattern": {
            "type": "string",
            "default": "^.*@todo.*?:",
            "description": "%memoTodoUserePattern.desc%"
          }
        }
      },
      {
        "title": "%config.group.admin%",
        "properties": {
          "memobox.memoAdminAppearance": {
            "type": "string",
            "enum": [
              "system",
              "light",
              "dark"
            ],
            "default": "system",
            "description": "%memoAdminAppearance.desc%"
          },
          "memobox.memoAdminColorTheme": {
            "type": "string",
            "enum": [
              "blue",
              "teal",
              "amber",
              "rose",
              "mono",
              "forest"
            ],
            "default": "blue",
            "description": "%memoAdminColorTheme.desc%"
          },
          "memobox.memoAdminUseGradient": {
            "type": "boolean",
            "default": false,
            "description": "%memoAdminUseGradient.desc%"
          },
          "memobox.memoAdminAdvancedMode": {
            "type": "boolean",
            "default": false,
            "description": "%memoAdminAdvancedMode.desc%"
          },
          "memobox.memoAdminOpenMode": {
            "type": "string",
            "enum": [
              "currentWindow",
              "newWindow"
            ],
            "default": "currentWindow",
            "markdownDescription": "%memoAdminOpenMode.desc%"
          },
          "memobox.memoAdminOpenOnStartup": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%memoAdminOpenOnStartup.desc%"
          },
          "memobox.memoPinnedFiles": {
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            },
            "markdownDeprecationMessage": "Pinned files are now stored in `.vscode-memobox/index.json`. Existing entries will be migrated automatically.",
            "description": "%memoPinnedFiles.desc%"
          },
          "memobox.memoRecentCount": {
            "type": "number",
            "default": 8,
            "minimum": 0,
            "maximum": 50,
            "description": "%memoRecentCount.desc%"
          },
          "memobox.memoMetaDir": {
            "type": "string",
            "default": ".vscode-memobox",
            "description": "%memoMetaDir.desc%"
          }
        }
      },
      {
        "title": "%config.group.markdownPreview%",
        "properties": {
          "memobox.openMarkdownPreview": {
            "type": "boolean",
            "default": false,
            "description": "%openMarkdownPreview.desc%"
          },
          "memobox.openMarkdownPreviewUseMPE": {
            "type": "boolean",
            "default": false,
            "description": "%openMarkdownPreviewUseMPE.desc%"
          }
        }
      },
      {
        "title": "%config.group.externalTools%",
        "properties": {
          "memobox.openChromeCustomizeURL": {
            "type": "string",
            "default": "data:text/html, <html contenteditable>",
            "description": "%openChromeCustomizeURL.desc%"
          }
        }
      },
      {
        "title": "%config.group.ai%",
        "properties": {
          "memobox.aiEnabled": {
            "type": "boolean",
            "default": false,
            "description": "%aiEnabled.desc%"
          },
          "memobox.aiProvider": {
            "type": "string",
            "default": "ollama",
            "enum": [
              "ollama",
              "openai"
            ],
            "description": "%aiProvider.desc%"
          },
          "memobox.aiEndpoint": {
            "type": "string",
            "default": "http://localhost:11434",
            "description": "%aiEndpoint.desc%"
          },
          "memobox.aiModel": {
            "type": "string",
            "default": "qwen3:1.7b",
            "description": "%aiModel.desc%"
          },
          "memobox.aiApiKey": {
            "type": "string",
            "default": "",
            "description": "%aiApiKey.desc%"
          },
          "memobox.aiTagLanguage": {
            "type": "string",
            "default": "auto",
            "enum": [
              "auto",
              "ja",
              "en"
            ],
            "description": "%aiTagLanguage.desc%"
          },
          "memobox.aiProxy": {
            "type": "string",
            "default": "",
            "description": "%aiProxy.desc%"
          },
          "memobox.aiProxyBypass": {
            "type": "string",
            "default": "",
            "description": "%aiProxyBypass.desc%"
          },
          "memobox.aiTlsRejectUnauthorized": {
            "type": "boolean",
            "default": true,
            "description": "%aiTlsRejectUnauthorized.desc%"
          },
          "memobox.aiTlsCaCert": {
            "type": "string",
            "default": "",
            "description": "%aiTlsCaCert.desc%"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "webpack": "webpack --mode development",
    "webpack-dev": "webpack --mode development --watch",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.json -w",
    "test-compile": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint src",
    "test": "npm run compile-tests && node --test out/test/test",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.8",
    "@types/mustache": "^4.2.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.0",
    "del": "^8.0.0",
    "eslint": "^9.11.1",
    "event-stream": "^4.0.1",
    "glob": "^11.0.0",
    "gulp": "^5.0.0",
    "gulp-filter": "^9.0.1",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-typescript": "^5.0.1",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.2",
    "vscode-nls-dev": "^4.0.4",
    "webpack": "^5.95.0",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "chrome-launcher": "^1.2.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "mustache": "^4.2.0",
    "node-emoji": "^1.11.0",
    "upath": "^2.0.1",
    "vscode-nls": "^5.2.0"
  }
}
